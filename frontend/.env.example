# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored — never commit your real keys.

# ── Fragrance API (Fragella) ──────────────────────────────────────────────────
VITE_FRAGRANCE_API_URL=https://api.fragella.com/api
VITE_FRAGRANCE_API_KEY=your_fragella_key_here

# ── Google AdSense ────────────────────────────────────────────────────────────
# 1. Apply at https://adsense.google.com — approval takes 1-7 days.
# 2. Once approved: create an ad unit (type: Display, format: Responsive).
# 3. Copy your publisher ID (ca-pub-...) and the ad slot ID below.
# 4. Uncomment the <script> tag in index.html and replace the publisher ID there too.
VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXXX
VITE_ADSENSE_SLOT=XXXXXXXXXX

# ── Awin affiliate (Notino + Lyko) ───────────────────────────────────────────
# 1. Sign up at https://www.awin.com/se (free).
# 2. Apply to "Notino" and "Lyko" in the advertiser directory.
# 3. Your publisher ID is shown on the Awin dashboard (7-digit number).
# 4. Merchant IDs are on each programme's overview page under "Programme Details".
#    Notino SE merchant ID is typically around 6300–6400 (verify on Awin).
#    Lyko merchant ID is typically around 14000+ (verify on Awin).
VITE_AWIN_PUBLISHER_ID=your_publisher_id
VITE_AWIN_NOTINO_MERCHANT=notino_merchant_id
VITE_AWIN_LYKO_MERCHANT=lyko_merchant_id
