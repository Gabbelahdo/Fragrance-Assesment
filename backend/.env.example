# Copy this to .env and fill in your values. Never commit .env.

# MongoDB — local docker-compose value shown, replace with Cosmos DB string for prod
MONGODB_URL=mongodb://root:localdev@localhost:27017/fragrance_db?authSource=admin

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# External APIs
FRAGRANCE_API_URL=https://api.fragella.com/api
FRAGRANCE_API_KEY=your-fragella-key

# Anthropic / Claude — get yours at https://console.anthropic.com/
# This is stored in AI_API_KEY to match the Settings model field name.
AI_API_KEY=sk-ant-your-key-here

# CORS — comma-separated, e.g. https://yourapp.azurestaticapps.net
CORS_ORIGINS=http://localhost:5173
